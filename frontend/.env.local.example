# Optional — baked in at build time for production client fetches:
# VITE_API_BASE_URL=https://shelftxt.onrender.com

# Demo banner + read-only UI (optional):
# VITE_DEMO_MODE=true   — force on (e.g. local preview of demo UI)
# VITE_DEMO_MODE=false  — force off explicitly

# Backend read-only (optional):
# DEMO_READ_ONLY=true

# Supabase Auth (frontend only; use the anon/public key, never the service role key).
# For local integration testing, this project must match backend SUPABASE_URL,
# and the backend DATABASE_URL must point at the Postgres database where this
# project's public.profiles rows are created.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
