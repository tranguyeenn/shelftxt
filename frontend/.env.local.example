# Optional — baked in at build time for production client fetches:
# VITE_API_BASE_URL=https://shelftxt.onrender.com

# Demo banner + read-only UI (optional overrides):
# Auto-enabled in production when using the shared Render API above.
# VITE_DEMO_MODE=true   — force on (e.g. local preview of demo UI)
# VITE_DEMO_MODE=false  — force off (self-hosted frontend on Vercel)

# Backend read-only (set on Render for the public demo API):
# DEMO_READ_ONLY=true

# Supabase Auth:
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
