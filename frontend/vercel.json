{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/recommend",
      "destination": "https://shelftxt.onrender.com/recommend"
    },
    {
      "source": "/api/books/import",
      "destination": "https://shelftxt.onrender.com/books/import"
    },
    {
      "source": "/api/books/export",
      "destination": "https://shelftxt.onrender.com/books/export"
    },
    {
      "source": "/api/books/clear",
      "destination": "https://shelftxt.onrender.com/books/clear"
    },
    {
      "source": "/api/books/:bookId/progress",
      "destination": "https://shelftxt.onrender.com/books/:bookId/progress"
    },
    {
      "source": "/api/books/:bookId",
      "destination": "https://shelftxt.onrender.com/books/:bookId"
    },
    {
      "source": "/api/books",
      "destination": "https://shelftxt.onrender.com/books"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
