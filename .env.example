# For Supabase Auth integration testing, point this at the same Supabase
# Postgres database that contains public.profiles rows for your auth users.
# Example shape only; do not commit real passwords:
# DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your_db_password@aws-0-region.pooler.supabase.com:6543/postgres
#
# Local Docker Postgres is valid for isolated backend work only, unless you
# manually insert profiles.id rows that match Supabase auth user UUIDs.
DATABASE_URL=postgresql+psycopg://shelftxt:shelftxt_dev_password@localhost:5432/shelftxt
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
