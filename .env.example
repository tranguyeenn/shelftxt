# For Supabase Auth integration testing, point this at the same Supabase
# Postgres database that contains public.profiles rows for your auth users.
# Example shape only; do not commit real passwords:
# DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your_db_password@aws-0-region.pooler.supabase.com:6543/postgres
#
# Local Docker Postgres is valid for isolated backend work only, unless you
# manually insert profiles.id rows that match Supabase auth user UUIDs.
DATABASE_URL=postgresql+psycopg://shelftxt:shelftxt_dev_password@localhost:5432/shelftxt
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_TIMEOUT_SECONDS=10
EMBEDDINGS_DEBUG_ENABLED=false
DISCOVERY_MAX_QUERIES=8
DISCOVERY_RESULTS_PER_QUERY=20
EXTERNAL_EXPLORATION_SUBJECTS_PER_DIMENSION=4
EXTERNAL_EXPLORATION_RESULTS_PER_SOURCE=12
RECOMMENDATION_LIBRARY_SHARE=0.35
RECOMMENDATION_EXTERNAL_SHARE=0.65
SECOND_AUTHOR_TITLE_SCORE_THRESHOLD=0.6
# Optional local Goodreads Kaggle CSV for description/genre fallback (backend only).
# GOODREADS_METADATA_CSV=metadata/book_details.csv
# Optional LibraryThing lightweight API token (backend enrichment only).
# LIBRARYTHING_API_TOKEN=your_librarything_api_token
# Optional Hardcover GraphQL discovery provider (backend only).
HARDCOVER_ENABLED=false
HARDCOVER_API_URL=https://api.hardcover.app/v1/graphql
# HARDCOVER_API_TOKEN=your_hardcover_api_token
HARDCOVER_TIMEOUT_SECONDS=2.5
HARDCOVER_MAX_RESULTS_PER_QUERY=12
HARDCOVER_MAX_QUERIES_PER_CLUSTER=1
# Optional New York Times Books API bestseller discovery provider (backend only).
NYT_BOOKS_ENABLED=false
NYT_BOOKS_API_URL=https://api.nytimes.com/svc/books/v3
# NYT_BOOKS_API_KEY=your_nyt_books_api_key
NYT_BOOKS_TIMEOUT_SECONDS=3
NYT_BOOKS_CACHE_SECONDS=21600
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
